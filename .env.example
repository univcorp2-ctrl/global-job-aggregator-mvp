# SQLite database path
DB_PATH=data/jobs.db

# Comma-separated target keywords. Keep these specific to avoid noisy collection.
JOB_KEYWORDS=AI Agent Developer,RAG,Vector Database,LangChain,LlamaIndex,OpenAI API,Claude API,Gemini API Integration,Workflow Automation,Zapier,Make,n8n,Web Scraping AI Analysis,LLM Evaluator,Code Evaluator,AI Real Estate,PropTech Automation

# Conservative collection limits
MAX_PER_SOURCE=50
REQUEST_DELAY_SECONDS=0.7
HTTP_TIMEOUT_SECONDS=20
CONTACT_EMAIL=you@example.com

# ATS public job-board targets. Add company tokens/slugs as you validate them.
GREENHOUSE_BOARDS=
LEVER_COMPANIES=
ASHBY_BOARDS=

# Optional paid/approved APIs
SERPAPI_API_KEY=
FREELANCER_OAUTH_TOKEN=

# Cooldowns in hours. Remotive asks developers not to request too frequently.
HIMALAYAS_COOLDOWN_HOURS=1
JOBICY_COOLDOWN_HOURS=1
ARBEITNOW_COOLDOWN_HOURS=1
REMOTIVE_COOLDOWN_HOURS=6
ATS_COOLDOWN_HOURS=6
SERPAPI_COOLDOWN_HOURS=6
FREELANCER_COOLDOWN_HOURS=6
